{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "./"
      ]
    },
    "foundry": {
      "command": "npx",
      "args": [
        "@pranesh.asp/foundry-mcp-server"
      ],
      "env": {
        "RPC_URL": "http://localhost:${PORT:-8545}"
      }
    }
  }
}