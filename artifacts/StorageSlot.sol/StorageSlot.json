\n }\n ```"},"fullyImplemented":true,"linearizedBaseContracts":[3982],"name":"StorageSlot","nameLocation":"1253:11:32","scope":3983,"usedErrors":[],"usedEvents":[]}],"license":"MIT"},"id":32}